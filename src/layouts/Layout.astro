---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro Markdown Documentation Site" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<style is:global>
			:root {
				--accent: 136, 58, 234;
				--accent-light: 224, 204, 250;
				--accent-dark: 49, 10, 101;
				--accent-gradient: linear-gradient(
					45deg,
					rgb(var(--accent)),
					rgb(var(--accent-light)) 30%,
					white 60%
				);
			}
			html {
				font-family: system-ui, sans-serif;
				background: #13151a;
				color: #fff;
			}
			body {
				margin: 0;
			}
			* {
				box-sizing: border-box;
			}
		</style>
	</head>
	<body>
		<header>
			<nav style="background: #23262d; padding: 1rem 2rem;">
				<a href="/" style="color: rgb(var(--accent-light)); text-decoration: none; font-weight: bold; font-size: 1.2rem;">
					🚀 Astro Docs
				</a>
				<div style="display: inline-block; margin-left: 2rem;">
					<a href="/docs" style="color: #fff; text-decoration: none; margin-right: 1rem;">Documentation</a>
					<a href="/about" style="color: #fff; text-decoration: none;">About</a>
				</div>
			</nav>
		</header>
		<main style="max-width: 1200px; margin: 0 auto; padding: 2rem;">
			<slot />
		</main>
		<footer style="background: #23262d; padding: 1rem 2rem; text-align: center; margin-top: 4rem;">
			<p style="color: #888; margin: 0;">Built with Astro 🚀</p>
		</footer>
	</body>
</html>
